<?xml version="1.0" encoding="UTF-8" ?>
<Defs>
    <HediffDef>
        <defName>ComaDrugHigh</defName>
        <hediffClass>Hediff_High</hediffClass>
        <label>comadrug</label>
        <description>Causes a Drug-induced coma that lasts 5.5 days.</description>
        <defaultLabelColor>(1,0,0.5)</defaultLabelColor>
        <scenarioCanAdd>false</scenarioCanAdd>
        <maxSeverity>1.0</maxSeverity>
        <isBad>false</isBad>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>-0.18</severityPerDay>
                <showHoursToRecover>true</showHoursToRecover>
            </li>
            <!-- A list of needs to maintain -->
            <li Class="BetterRimworlds.ComaDrug.HediffCompProperties_MinimumNeed">
                <!-- A list of needs to maintain -->
                <needs>
                    <li>
                        <needDef>Chemical_Luciferium</needDef>
                        <minLevel>0.05</minLevel>
                    </li>
                    <li>
                        <needDef>Mood</needDef>
                        <minLevel>1.00</minLevel>
                    </li>
                    <li>
                        <needDef>Joy</needDef>
                        <minLevel>1.00</minLevel>
                    </li>
                </needs>
            </li>
            <li Class="BetterRimworlds.ComaDrug.HediffCompProperties_ModifyNeedRate">
                <needs>
                    <li>
                        <needDef>Chemical_Luciferium</needDef>
                        <rateFactor>0.25</rateFactor>
                    </li>
                </needs>
            </li>
            <li Class="BetterRimworlds.ComaDrug.HediffCompProperties_WakeOnHediff">
                <wakeHediff>WakeUpHigh</wakeHediff>
            </li>
        </comps>
        <stages>
            <li>
                <minSeverity>0.0</minSeverity>
                <label>Medical Coma</label>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <setMax>0.01</setMax>
                    </li>
                    <li>
                        <capacity>Moving</capacity>
                        <setMax>0.0</setMax>
                    </li>
                    <li>
                        <capacity>Manipulation</capacity>
                        <setMax>0.0</setMax>
                    </li>
                </capMods>
                <statFactors>
                    <!-- Doubles the speed at which diseases are fought off. -->
                    <ImmunityGainSpeed>2.0</ImmunityGainSpeed>
                </statFactors>
                <!-- Reduce hunger rate to 15% of normal -->
                <hungerRateFactor>0.15</hungerRateFactor>
            </li>
        </stages>
    </HediffDef>
</Defs>
