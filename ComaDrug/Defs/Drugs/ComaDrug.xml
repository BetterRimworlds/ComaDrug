<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<ThingDef ParentName="DrugPillBase">
		<defName>ComaDrug</defName>
		<label>coma drug</label>
		<description>A neurodegenerative drug that induces a medical coma for 5.55 days.</description>
		<graphicData>
			<texPath>Things/Drugs</texPath>
			<graphicClass>Graphic_StackCount</graphicClass>
		</graphicData>
		<rotatable>false</rotatable>
		<statBases>
			<MarketValue>700</MarketValue>
			<Mass>0.01</Mass>
		</statBases>
		<techLevel>Ultra</techLevel>
		<minRewardCount>1</minRewardCount>
		<ingestible>
			<drugCategory>Medical</drugCategory>
			<outcomeDoers>
				<li Class="IngestionOutcomeDoer_GiveHediff">
					<hediffDef>ComoDrugHigh</hediffDef>
					<!-- <hediffDef>PenoxycylineHigh</hediffDef> -->
					<severity>1.00</severity>
				</li>
			</outcomeDoers>
		</ingestible>
		<comps>
			<li Class="CompProperties_Drug">
				<listOrder>1000</listOrder>
				<overdoseSeverityOffset>0.08~0.14</overdoseSeverityOffset>
			</li>
		</comps>
		<tradeTags>
			<li>ExoticMisc</li>
		</tradeTags>
		<thingSetMakerTags><li>RewardStandardLowFreq</li></thingSetMakerTags>
	</ThingDef>

	<HediffDef>
		<defName>ComoDrugHigh</defName>
		<hediffClass>Hediff_High</hediffClass>
		<label>comadrug</label>
		<description>Causes a Drug-induced coma that lasts 5.5 days.</description>
		<defaultLabelColor>(1,0,0.5)</defaultLabelColor>
		<scenarioCanAdd>false</scenarioCanAdd>
		<maxSeverity>1.0</maxSeverity>
		<isBad>false</isBad>
		<comps>
			<li Class="HediffCompProperties_SeverityPerDay">
				<severityPerDay>-0.18</severityPerDay>
				<showHoursToRecover>true</showHoursToRecover>
			</li>
		</comps>
		<stages>
			<li>
				<minSeverity>0.0</minSeverity>
				<label>Medical Coma</label>
				<capMods>
					<li>
						<capacity>Consciousness</capacity>
						<setMax>0.01</setMax>
					</li>
					<li>
						<capacity>Moving</capacity>
						<setMax>0.0</setMax>
					</li>
					<li>
						<capacity>Manipulation</capacity>
						<setMax>0.0</setMax>
					</li>
				</capMods>
				<!-- Reduce hunger rate to 15% of normal -->
				<hungerRateFactor>0.15</hungerRateFactor>
			</li>
		</stages>
	</HediffDef>

  <!-- RecipeDef for crafting the Coma Drug -->
  <RecipeDef>
    <defName>MakeComaDrug</defName>
    <label>make coma drug</label>
    <description>Craft Coma Drug at a Drug Lab.</description>
    <jobString>Making Coma Drug.</jobString>
    <effectWorking>Cremate</effectWorking>
    <workSpeedStat>DrugSynthesisSpeed</workSpeedStat>
    <workAmount>400</workAmount>
    <researchPrerequisite>MedicalComaDrug</researchPrerequisite>
    <recipeUsers>
      <li>DrugLab</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>DevilstrandCloth</li>
          </thingDefs>
        </filter>
        <count>10</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>MedicineIndustrial</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Luciferium</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>DevilstrandCloth</li>
        <li>MedicineIndustrial</li>
        <li>Luciferium</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <ComaDrug>1</ComaDrug>
    </products>
    <skillRequirements>
      <Crafting>8</Crafting>
      <Intellectual>10</Intellectual>
    </skillRequirements>
  </RecipeDef>
  <RecipeDef>
    <defName>MakeComaDrugBulk</defName>
    <label>make coma drug x5</label>
    <description>Craft 5 Coma DrugSynthesis at a Drug Lab.</description>
    <jobString>Making 5 Coma Drugs.</jobString>
    <effectWorking>Cremate</effectWorking>
    <workSpeedStat>DrugSynthesisSpeed</workSpeedStat>
    <workAmount>1000</workAmount>
    <researchPrerequisite>MedicalComaDrug</researchPrerequisite>
    <recipeUsers>
      <li>DrugLab</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>DevilstrandCloth</li>
          </thingDefs>
        </filter>
        <count>50</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>MedicineIndustrial</li>
          </thingDefs>
        </filter>
        <count>5</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Luciferium</li>
          </thingDefs>
        </filter>
        <count>5</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>DevilstrandCloth</li>
        <li>MedicineIndustrial</li>
        <li>Luciferium</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <ComaDrug>5</ComaDrug>
    </products>
    <skillRequirements>
      <Crafting>8</Crafting>
      <Intellectual>10</Intellectual>
    </skillRequirements>
  </RecipeDef>
</Defs>
